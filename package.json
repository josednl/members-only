    "@types/node": "^25.9.3",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "concurrently": "^10.0.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"

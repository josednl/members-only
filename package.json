    "express": "^5.2.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/ejs": "^3.1.5",

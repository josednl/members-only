<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-white shadow-md p-4 mb-8">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="text-xl font-bold text-blue-600">Members Only</a>
            <div>
                <% if (locals.currentUser) { %>
                    <span class="mr-4 text-gray-600">Welcome, <%= currentUser.firstName %>!</span>
                    <form action="/logout" method="POST" class="inline">
                        <button type="submit" class="text-red-500 hover:text-red-700 font-semibold">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="mr-4 text-gray-600 hover:text-blue-600">Login</a>
                    <a href="/sign-up" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">Sign Up</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-4">
        <h1 class="text-4xl font-bold text-center mb-8"><%= title %></h1>
        
        <div class="max-w-2xl mx-auto bg-white p-6 rounded shadow-md">
            <% if (locals.currentUser) { %>
                <p class="text-center text-lg">You are logged in. Soon you will see messages here!</p>
            <% } else { %>
                <p class="text-center text-lg">Join our exclusive club to see who's talking and when!</p>
                <div class="mt-6 flex justify-center">
                    <a href="/sign-up" class="bg-blue-500 text-white px-6 py-3 rounded-lg text-lg font-bold hover:bg-blue-600 transition">Get Started</a>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>

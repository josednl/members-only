<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-white shadow-md p-4 mb-8">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="text-xl font-bold text-blue-600">Members Only</a>
            <div>
                <% if (locals.currentUser) { %>
                    <span class="mr-4 text-gray-600">Welcome, <%= currentUser.firstName %>!</span>
                    <form action="/logout" method="POST" class="inline">
                        <button type="submit" class="text-red-500 hover:text-red-700 font-semibold">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="mr-4 text-gray-600 hover:text-blue-600">Login</a>
                    <a href="/sign-up" class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">Sign Up</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-4">
        <h1 class="text-4xl font-bold text-center mb-8"><%= title %></h1>

        <% if (locals.currentUser) { %>
            <div class="text-center mb-6">
                <a href="/messages/new" class="bg-blue-500 text-white px-6 py-3 rounded-lg text-lg font-bold hover:bg-blue-600 transition inline-block">New Message</a>
            </div>
        <% } %>

        <div class="max-w-2xl mx-auto space-y-4">
            <% if (locals.messages && messages.length > 0) { %>
                <% messages.forEach(function(message) { %>
                    <div class="bg-white p-6 rounded shadow-md">
                        <h2 class="text-xl font-bold mb-2"><%= message.title %></h2>
                        <p class="text-gray-700 mb-4 whitespace-pre-wrap"><%= message.text %></p>
                        <div class="text-sm text-gray-500 flex justify-between items-center">
                            <span>
                                <% if (locals.currentUser && currentUser.isMember) { %>
                                    Posted by <%= message.author.firstName %> <%= message.author.lastName %>
                                <% } else { %>
                                    Posted anonymously
                                <% } %>
                            </span>
                            <span><%= message.timestamp.toLocaleString() %></span>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="bg-white p-6 rounded shadow-md text-center">
                    <p class="text-gray-500 text-lg">No messages yet.</p>
                    <% if (locals.currentUser) { %>
                        <p class="mt-2">Be the first to <a href="/messages/new" class="text-blue-500 hover:text-blue-700 font-semibold">post a message</a>!</p>
                    <% } else { %>
                        <p class="mt-2"><a href="/sign-up" class="text-blue-500 hover:text-blue-700 font-semibold">Sign up</a> to post a message!</p>
                    <% } %>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>
